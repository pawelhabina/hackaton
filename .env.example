# Required for AI-generated chat replies.
GEMINI_API_KEY=your_gemini_api_key

# Optional. Default model used by the chat backend.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Frontend build-time URL of the API, for separate hosting.
# Example: https://api.twoja-domena.pl
VITE_API_BASE_URL=

# Optional. Comma-separated frontend origins allowed to call the API.
# Example: https://twoja-domena.pl,http://localhost:5173
CORS_ALLOW_ORIGIN=

# Optional. Backend port. Production platforms often set PORT automatically.
CHAT_PORT=8787
